{
  "info": {
    "name": "Squad-X | Climbe",
    "description": "Climbe API — coleção completa.\n\nFluxo: rode **Auth > Login** primeiro (preenche `access_token`). Os demais requests herdam o Bearer automaticamente.\n\nVariáveis: `base_url`, `admin_email`, `admin_password`, `access_token` e os `id_*` usados nos path params.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    },
    {
      "key": "admin_email",
      "value": "admin@climbe.local"
    },
    {
      "key": "admin_password",
      "value": "change-me-admin-password"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "id_cargo",
      "value": "1"
    },
    {
      "key": "id_usuario",
      "value": "1"
    },
    {
      "key": "id_empresa",
      "value": "1"
    },
    {
      "key": "id_proposta",
      "value": "1"
    },
    {
      "key": "id_contrato",
      "value": "1"
    },
    {
      "key": "id_documento",
      "value": "1"
    }
  ],
